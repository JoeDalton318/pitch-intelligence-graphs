
# MinIO – accès depuis le cloud via tunnel ngrok
# Remplacez par l'URL générée par : ngrok http 9000
# ------------------------------
MINIO_ENDPOINT_URL=https://<votre-id>.ngrok-free.app
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=<votre-mot-de-passe-minio>

# Databricks – déclenchement du job Silver depuis Airflow
# Récupérez le token dans : Databricks → User Settings → Access Tokens
# ------------------------------
DATABRICKS_HOST=https://<votre-workspace-id>.cloud.databricks.com
DATABRICKS_TOKEN=<votre-token-dapi-databricks>
