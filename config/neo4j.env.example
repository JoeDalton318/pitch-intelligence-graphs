
# Neo4j – connexion à l'instance locale (Docker)
# Démarrez Neo4j avec : docker compose --profile graph up -d neo4j
# ------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<votre-mot-de-passe-neo4j>

# Si Neo4j est exposé via ngrok pour Databricks :
# NEO4J_URI=bolt://<votre-id>.ngrok-free.app:7687
